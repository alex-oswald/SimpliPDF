<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="SimpliPDF.Dialogs.ScanDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Scan"
    PrimaryButtonText="Scan"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False"
    PrimaryButtonClick="OnPrimaryButtonClick">

    <Grid MinWidth="500" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Settings row -->
        <StackPanel Spacing="12">
            <ComboBox x:Name="ScannerCombo"
                      Header="Scanner"
                      HorizontalAlignment="Stretch"
                      PlaceholderText="Searching for scanners..."
                      SelectionChanged="OnScannerSelectionChanged"
                      DisplayMemberPath="Name" />

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="DpiCombo"
                          Header="Resolution"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="Select scanner first"
                          IsEnabled="False" />

                <ComboBox x:Name="ColorModeCombo"
                          Grid.Column="1"
                          Header="Color mode"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="Select scanner first"
                          IsEnabled="False" />
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="PreviewButton"
                        Content="Preview"
                        Click="OnPreviewClick"
                        IsEnabled="False" />
                <HyperlinkButton x:Name="ResetCropButton"
                                 Content="Reset crop"
                                 Click="OnResetCropClick"
                                 Visibility="Collapsed"
                                 VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <!-- Progress bar with cancel -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressBar x:Name="ScanProgress"
                         IsIndeterminate="True"
                         Visibility="Collapsed"
                         VerticalAlignment="Center" />

            <Button x:Name="CancelOperationButton"
                    Grid.Column="1"
                    Content="Cancel"
                    Click="OnCancelOperationClick"
                    CornerRadius="4"
                    Visibility="Collapsed" />
        </Grid>

        <!-- Preview image area -->
        <Border Grid.Row="2"
                MinHeight="300"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8">
            <Grid>
                <!-- Placeholder text -->
                <TextBlock x:Name="PreviewPlaceholder"
                           Text="Click Preview to see a scan preview"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.5"
                           Style="{StaticResource BodyTextBlockStyle}" />

                <!-- Preview image -->
                <Image x:Name="PreviewImage"
                       Stretch="Uniform"
                       Visibility="Collapsed" />

                <!-- Crop overlay canvas -->
                <Canvas x:Name="CropCanvas"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Visibility="Collapsed"
                        PointerPressed="OnCropPointerPressed"
                        PointerMoved="OnCropPointerMoved"
                        PointerReleased="OnCropPointerReleased">
                    <Rectangle x:Name="DimTop" Fill="#40000000" />
                    <Rectangle x:Name="DimBottom" Fill="#40000000" />
                    <Rectangle x:Name="DimLeft" Fill="#40000000" />
                    <Rectangle x:Name="DimRight" Fill="#40000000" />
                    <Rectangle x:Name="CropRect"
                               Stroke="White"
                               StrokeThickness="2"
                               StrokeDashArray="4 4"
                               Visibility="Collapsed" />

                    <!-- Resize handles -->
                    <Rectangle x:Name="HandleTL" Width="10" Height="10" Fill="White" Visibility="Collapsed" />
                    <Rectangle x:Name="HandleT"  Width="10" Height="10" Fill="White" Visibility="Collapsed" />
                    <Rectangle x:Name="HandleTR" Width="10" Height="10" Fill="White" Visibility="Collapsed" />
                    <Rectangle x:Name="HandleL"  Width="10" Height="10" Fill="White" Visibility="Collapsed" />
                    <Rectangle x:Name="HandleR"  Width="10" Height="10" Fill="White" Visibility="Collapsed" />
                    <Rectangle x:Name="HandleBL" Width="10" Height="10" Fill="White" Visibility="Collapsed" />
                    <Rectangle x:Name="HandleB"  Width="10" Height="10" Fill="White" Visibility="Collapsed" />
                    <Rectangle x:Name="HandleBR" Width="10" Height="10" Fill="White" Visibility="Collapsed" />
                </Canvas>
            </Grid>
        </Border>

        <!-- Status text -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Opacity="0.6" />
    </Grid>
</ContentDialog>
