<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SimpliPDF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SimpliPDF"
    xmlns:models="using:SimpliPDF.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SimpliPDF"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <TitleBar x:Name="AppTitleBar" Title="SimpliPDF">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <!-- Command Bar — global document actions -->
        <CommandBar Grid.Row="1" DefaultLabelPosition="Right" IsOpen="False">
            <AppBarButton Icon="OpenFile" Label="Open" Click="OnOpenClick"
                          KeyboardAcceleratorTextOverride="Ctrl+O">
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="O" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton x:Name="ScanBtn" Label="Scan" Click="OnScanClick" IsEnabled="False">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8FE;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="PrintBtn" Icon="Print" Label="Print" Click="OnPrintClick"
                          IsEnabled="False" KeyboardAcceleratorTextOverride="Ctrl+P">
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="P" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton x:Name="SplitBtn" Label="Split All" Click="OnSplitClick"
                          IsEnabled="False">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8A9;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="SaveBtn" Icon="Save" Label="Save Merged" Click="OnSaveClick"
                          IsEnabled="False" KeyboardAcceleratorTextOverride="Ctrl+S">
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="S" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
        </CommandBar>

        <!-- Contextual selection toolbar — appears above the grid when pages are selected -->
        <CommandBar x:Name="SelectionBar" Grid.Row="2" DefaultLabelPosition="Right" IsOpen="False"
                    Visibility="Collapsed"
                    Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,1">
            <CommandBar.Content>
                <TextBlock x:Name="SelectionCountText"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
            </CommandBar.Content>
            <AppBarButton x:Name="RotateBtn" Label="Rotate" Click="OnRotateClick"
                          KeyboardAcceleratorTextOverride="Ctrl+R">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE7AD;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="R" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton x:Name="DuplicateBtn" Label="Duplicate" Click="OnDuplicateClick"
                          KeyboardAcceleratorTextOverride="Ctrl+D">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8C8;" />
                </AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="D" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton x:Name="CropBtn" Label="Crop" Click="OnCropClick"
                          IsEnabled="False">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE123;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="ExtractBtn" Label="Save Page" Click="OnExtractClick">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8B5;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton x:Name="DeleteBtn" Icon="Delete" Label="Delete" Click="OnDeleteClick"
                          KeyboardAcceleratorTextOverride="Del">
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Delete" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton x:Name="DeselectBtn" Label="Deselect All" Click="OnDeselectAllClick">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8E6;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- Main content area — this is the drop target -->
        <Grid Grid.Row="3"
              AllowDrop="True"
              DragOver="OnDragOver"
              Drop="OnDrop"
              Background="Transparent">

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="12">
                <FontIcon Glyph="&#xE8E5;" FontSize="64" Opacity="0.4" HorizontalAlignment="Center" />
                <TextBlock Text="Drop PDF files here or click Open"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Opacity="0.6" HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Loading overlay -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="48" Height="48"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Page thumbnails -->
            <GridView x:Name="PagesGridView"
                      ItemsSource="{x:Bind ViewModel.Pages}"
                      SelectionMode="Extended"
                      CanReorderItems="True"
                      CanDragItems="True"
                      AllowDrop="True"
                      DragOver="OnDragOver"
                      Drop="OnDrop"
                      Padding="12">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:PdfPageItem">
                        <Grid Width="{x:Bind CardWidth, Mode=OneWay}" Padding="4" RowSpacing="4"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1" CornerRadius="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Image Source="{x:Bind DisplayThumbnail, Mode=OneWay}"
                                   Stretch="Uniform"
                                   Height="{x:Bind ImageHeight, Mode=OneWay}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                                <Image.RenderTransform>
                                    <RotateTransform Angle="{x:Bind Rotation, Mode=OneWay}" />
                                </Image.RenderTransform>
                            </Image>

                            <TextBlock Grid.Row="1"
                                       Text="{x:Bind DisplayLabel}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Padding="2,0,2,4"
                                       MaxLines="1" />
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="4"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}" />
        </Border>
    </Grid>
</Window>
